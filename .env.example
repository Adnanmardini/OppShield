# ──────────────────────────────────────────────────────────────────
#  OpsShield — Environment Variables
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
#  In production, load these from AWS Secrets Manager.
# ──────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# Database — get from Cloud team (RDS endpoint in Secrets Manager)
DATABASE_URL=postgresql://opsshield:password@localhost:5432/opsshield

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# In production these must come from AWS Secrets Manager, never hardcoded
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING

# Paystack — get from Paystack dashboard
# Use test keys in development, live keys in production (from Secrets Manager only)
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_KEY

# Email — Nodemailer config for invites and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_EMAIL
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_FROM=noreply@opsshield.io

# Logging
LOG_LEVEL=info
