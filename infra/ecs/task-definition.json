{
  "family": "opsshield/dev",
  "taskRoleArn": "arn:aws:iam::541592468666:role/opsshield-dev-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::541592468666:role/opsshield-dev-ecs-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "opsshield-app",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/opsshield:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "PRISMA_QUERY_ENGINE_LIBRARY",
          "value": "/app/node_modules/@prisma/engines/libquery_engine-debian-openssl-3.0.x.so.node"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:541592468666:secret:opsshield/dev/database-url-YaWFD5"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:541592468666:secret:opsshield/dev/jwt-signing-secret-cU33bK"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:541592468666:secret:opsshield/dev/jwt-refresh-secret-YaWFD5"
        },
        {
          "name": "PAYSTACK_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:541592468666:secret:opsshield/dev/paystack-secret-key-U7rNAP"
        },
        {
          "name": "PAYSTACK_PUBLIC_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:541592468666:secret:opsshield/dev/paystack-public-key-OzVejJ"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/opsshield-dev",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
